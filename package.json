{
  "name": "gaslibraryfactory-monorepo",
  "version": "3.0.0",
  "description": "Google Apps Script Library Factory - Monorepo with ES Modules and Webpack bundling",
  "type": "module",
  "main": "dist/Code.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:readable": "webpack --mode production --env readable",
    "build:production": "node scripts/build-and-prepare.cjs --mode=production",
    "build:testing": "node scripts/build-and-prepare.cjs --mode=testing",
    "build:testoffline": "node scripts/build-and-prepare.cjs --mode=testoffline",
    "build:testoffline:bundle": "node scripts/build-and-prepare.cjs --mode=testoffline --include-offline-tests=true",
    "watch": "webpack --watch --mode production --env readable",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "push:production": "npm run build:production && clasp push",
    "push:testing": "npm run build:testing && clasp push",
    "docs": "node scripts/generate-docs.js",
    "docs:watch": "node scripts/generate-docs.js --watch",
    "test": "jest --reporters=summary --silent --no-stack-trace",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:single": "jest --testNamePattern",
    "test:integration": "jest --config jest.integration.config.cjs",
    "test:integration:watch": "jest --config jest.integration.config.cjs --watch",
    "test:integration:coverage": "jest --config jest.integration.config.cjs --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "library",
    "monorepo",
    "webpack",
    "es-modules",
    "resilience",
    "error-handling",
    "templating",
    "orm",
    "background-jobs"
  ],
  "author": "GasLibraryFactory",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.5.0",
    "@google/clasp": "^2.4.2",
    "babel-jest": "^30.4.1",
    "babel-loader": "^9.1.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "gas-webpack-plugin": "^2.3.0",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "jsdoc": "^4.0.2",
    "jsdoc-api": "^9.3.6",
    "jsdoc-to-markdown": "^8.0.0",
    "prettier": "^3.9.5",
    "webpack": "^5.108.4",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/giulioleuci/gaslibfactory.git"
  },
  "clasp": {
    "scriptId": "YOUR_SCRIPT_ID_HERE",
    "rootDir": "./dist"
  },
  "dependencies": {
    "es-toolkit": "^1.43.0",
    "fuse.js": "^7.5.0",
    "he": "^1.2.0",
    "jsep": "^1.4.0",
    "zod": "^4.4.3"
  }
}
